{
  "name": "@autoxi/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "rating-lab": "tsx src/ingestion/rating-lab/cli/runRatingLab.ts",
    "rating-lab:loop": "tsx src/ingestion/rating-lab/cli/runRatingLabLoop.ts",
    "rating-lab:gate": "tsx src/ingestion/rating-lab/cli/runRatingGateCheck.ts",
    "rating-lab:compare": "tsx src/ingestion/rating-lab/cli/runRatingLabCompare.ts",
    "rating-lab:preview": "tsx src/ingestion/rating-lab/cli/runRatingLabPreview.ts",
    "rating-lab:write-dev-preview": "tsx src/ingestion/rating-lab/cli/runRatingLabWriteDevPreview.ts",
    "rating-lab:profile-sources": "tsx src/ingestion/rating-lab/cli/runRatingLabProfileSources.ts",
    "rating-lab:profile-transfermarkt": "tsx src/ingestion/rating-lab/cli/runRatingLabProfileTransfermarkt.ts"
  },
  "dependencies": {
    "@autoxi/domain": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
