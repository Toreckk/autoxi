{
  "name": "autoxi",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "corepack pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" --parallel dev",
    "dev:api": "corepack pnpm -F @autoxi/api dev",
    "dev:web": "corepack pnpm -F @autoxi/web dev",
    "build": "corepack pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "test": "corepack pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" test",
    "lint": "corepack pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" lint",
    "db:generate": "corepack pnpm -F @autoxi/db db:generate",
    "db:migrate": "corepack pnpm -F @autoxi/db db:migrate",
    "db:seed": "corepack pnpm -F @autoxi/db db:seed",
    "db:studio": "corepack pnpm -F @autoxi/db db:studio",
    "db:rating-lab": "corepack pnpm --filter @autoxi/db rating-lab",
    "db:rating-lab:loop": "corepack pnpm --filter @autoxi/db rating-lab:loop",
    "db:rating-lab:gate": "corepack pnpm --filter @autoxi/db rating-lab:gate",
    "db:rating-lab:compare": "corepack pnpm --filter @autoxi/db rating-lab:compare",
    "db:rating-lab:preview": "corepack pnpm --filter @autoxi/db rating-lab:preview",
    "db:rating-lab:write-dev-preview": "corepack pnpm --filter @autoxi/db rating-lab:write-dev-preview",
    "db:rating-lab:profile-sources": "corepack pnpm --filter @autoxi/db rating-lab:profile-sources",
    "db:rating-lab:profile-transfermarkt": "corepack pnpm --filter @autoxi/db rating-lab:profile-transfermarkt",
    "db:rating-lab:export-enrichment": "corepack pnpm --filter @autoxi/db rating-lab:export-enrichment",
    "db:transfermarkt:coverage": "corepack pnpm --filter @autoxi/db transfermarkt:coverage",
    "db:transfermarkt:enrich": "corepack pnpm --filter @autoxi/db transfermarkt:enrich",
    "db:transfermarkt:apply-reviewed": "corepack pnpm --filter @autoxi/db transfermarkt:apply-reviewed",
    "db:transfermarkt:merge-preview": "corepack pnpm --filter @autoxi/db transfermarkt:merge-preview"
  }
}
